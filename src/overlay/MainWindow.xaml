<Window x:Class="GestureOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gesture Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    
    <Window.Resources>
        <!-- Glow effects and sleek modern brushes -->
        <DropShadowEffect x:Key="GlowEffect" BlurRadius="15" Color="#00F0FF" ShadowDepth="0" Opacity="0.8"/>
        <DropShadowEffect x:Key="OrangeGlowEffect" BlurRadius="20" Color="#FF8A00" ShadowDepth="0" Opacity="0.9"/>
        <DropShadowEffect x:Key="PurpleGlowEffect" BlurRadius="25" Color="#8B00FF" ShadowDepth="0" Opacity="0.8"/>
        
        <Style x:Key="HudLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold, Outfit, Inter, Arial"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#80FFFFFF"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <!-- Main Overlay Drawing Canvas for hand skeletons -->
        <Canvas x:Name="HandCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- Gaze Cursor Blob Indicator -->
        <Canvas x:Name="CursorCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Ellipse x:Name="GazeCursor" Width="18" Height="18" Fill="#00F0FF" Opacity="0.75" Effect="{StaticResource GlowEffect}">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="-9" Y="-9"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <!-- Calibration Dot layer (hidden during standard operation) -->
        <Canvas x:Name="CalibrationCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Collapsed">
            <Ellipse x:Name="CalibrationTarget" Width="40" Height="40" Fill="Transparent" Stroke="#FF8A00" StrokeThickness="4" Effect="{StaticResource OrangeGlowEffect}">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="-20" Y="-20"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="CalibrationTargetCenter" Width="10" Height="10" Fill="#FF8A00">
                <Ellipse.RenderTransform>
                    <TranslateTransform X="-5" Y="-5"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <TextBlock x:Name="CalibrationText" Foreground="#FF8A00" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Text="Pinch/Hold here" Canvas.Left="0" Canvas.Top="0"/>
        </Canvas>

        <!-- Dynamic HUD Panel (Glassmorphism design, located top-right) -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="30" CornerRadius="12" Padding="20" Width="260"
                Background="#1A0A0E17" BorderBrush="#33FFFFFF" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="#000000" Opacity="0.5" ShadowDepth="5"/>
            </Border.Effect>
            
            <StackPanel>
                <TextBlock Text="JANUS HUD" FontSize="11" FontWeight="Bold" Foreground="#FF8A00" Margin="0,0,0,10"/>
                
                <!-- Connection State indicator -->
                <Grid Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="ConnectionLed" Width="8" Height="8" Fill="#FF3B30" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ConnectionStateText" Grid.Column="1" Text="DISCONNECTED" Style="{StaticResource HudLabelStyle}" FontWeight="Bold"/>
                </Grid>

                <Separator Background="#20FFFFFF" Margin="0,10,0,10"/>

                <!-- Active FSM State -->
                <TextBlock Text="GESTURE STATE" Style="{StaticResource HudLabelStyle}"/>
                <TextBlock x:Name="StateText" Text="HOVER" FontSize="28" FontWeight="ExtraBold" Foreground="#00F0FF" Effect="{StaticResource GlowEffect}"/>

                <!-- Calibration reminder or status -->
                <TextBlock Text="CALIBRATION PROFILE" Style="{StaticResource HudLabelStyle}" Margin="0,10,0,2"/>
                <TextBlock x:Name="CalibrationProfileStatus" Text="DEFAULT (UNINITIALIZED)" FontSize="12" FontWeight="SemiBold" Foreground="#FFFF3B"/>

                <!-- Swipe feedback indicator -->
                <TextBlock x:Name="SwipeAlertText" Text="SWIPE DETECTED!" FontSize="16" FontWeight="Bold" Foreground="#8B00FF" 
                           Opacity="0" Effect="{StaticResource PurpleGlowEffect}" HorizontalAlignment="Center" Margin="0,15,0,0"/>

                <Button x:Name="CalibrateButton" Content="RUN CALIBRATION" Height="32" Margin="0,15,0,0" 
                        Background="#FF8A00" Foreground="White" BorderThickness="0" FontWeight="Bold"
                        Click="CalibrateButton_Click">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFAD42"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
